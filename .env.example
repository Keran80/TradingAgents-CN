# TradingAgents-CN 环境配置模板
# 复制此文件为 .env 并填入你的API密钥
# ====================

# ========== LLM 配置 (智谱AI) ==========
LLM_PROVIDER=openai
DEEP_THINK_LLM=glm-4-flash
QUICK_THINK_LLM=glm-4-flash
BACKEND_URL=https://open.bigmodel.cn/api/paas/v4

# 请在智谱AI平台获取API密钥: https://open.bigmodel.cn/
OPENAI_API_KEY=your_zhipu_api_key_here
ZHIPU_API_KEY=your_zhipu_api_key_here

# ========== A股数据 (AkShare - 免费开源) ==========
# 无需配置，直接使用

# ========== 美股数据 (FinnHub - 可选) ==========
# 免费注册: https://finnhub.io/
# FINNHUB_API_KEY=your_finnhub_api_key_here

# ========== 可选配置 ==========
# 自定义结果保存目录
# TRADINGAGENTS_RESULTS_DIR=./results
