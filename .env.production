# 生产环境配置

# 基本配置
ENV=production
DEBUG=False
LOG_LEVEL=WARNING

# API 配置
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Streamlit 配置
STREAMLIT_PORT=8501
STREAMLIT_HEAD=True

# 数据库配置
DATABASE_URL=postgresql://user:password@localhost:5432/tradingagents

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379

# 数据源配置
DATA_SOURCE=akshare
DATA_CACHE_TTL=300

# 安全配置
SECRET_KEY=your-secret-key-change-in-production
CORS_ORIGINS=["https://your-domain.com"]
