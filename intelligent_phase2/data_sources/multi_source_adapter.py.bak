                    df['datetime'] = pd.to_datetime(df['date'].astype(str) + ' ' + df['time'].astype(str))
                    df.set_index('datetime', inplace=True)
                else:
                    df.set_index('date', inplace=True)
            
            # 只保留请求的字段
            available_columns = [col for col in request.fields if col in df.columns]
            if not available_columns:
                available_columns = ['open', 'high', 'low', 'close', 'volume']
            
            result = df[available_columns]
            
            logger.debug(f"✅ AKShare获取成功: {len(result)} 条数据")
            return result
            
        except Exception as e:
            logger.error(f"❌ AKShare获取失败: {e}")
            return pd.DataFrame()
    
    async def _fetch_tushare(self, request: DataRequest) -> pd.DataFrame:
        """从Tushare获取数据"""
        logger.debug(f"📡 从Tushare获取 {request.symbol} 数据")
        
        try:
            import tushare as ts
            
            # 设置token（如果有）
            tushare_token = self.config.get("tushare_token")
            if tushare_token:
                ts.set_token(tushare_token)
            
            pro = ts.pro_api()
            
            # Tushare股票代码格式
            symbol = request.symbol
            if not symbol.endswith(('.SH', '.SZ')):
                # 添加后缀
                if symbol.startswith('6'):
                    symbol = f"{symbol}.SH"
                else:
                    symbol = f"{symbol}.SZ"
            
            # 获取日线数据
            df = pro.daily(
                ts_code=symbol,
                start_date=request.start_date,
                end_date=request.end_date
            )
            
            if df.empty:
                logger.warning(f"⚠️  Tushare返回空数据: {symbol}")
                return pd.DataFrame()
            
            # 重命名和格式化
            df['trade_date'] = pd.to_datetime(df['trade_date'])
            df.set_index('trade_date', inplace=True)
            df.sort_index(inplace=True)
            
            # 重命名列
            column_mapping = {
                'open': 'open',
                'high': 'high',
                'low': 'low',
                'close': 'close',
                'vol': 'volume',
                'amount': 'amount',
                'pct_chg': 'change_pct'
            }
            
            df = df.rename(columns={k: v for k, v in column_mapping.items() if k in df.columns})
            
            # 只保留请求的字段
            available_columns = [col for col in request.fields if col in df.columns]
            if not available_columns:
                available_columns = ['open', 'high', 'low', 'close', 'volume']
            
            result = df[available_columns]
            
            logger.debug(f"✅ Tushare获取成功: {len(result)} 条数据")
            return result
            
        except Exception as e:
            logger.error(f"❌ Tushare获取失败: {e}")
            return pd.DataFrame()
    
    async def _fetch_yfinance(self, request: DataRequest) -> pd.DataFrame:
        """从Yahoo Finance获取数据"""
        logger.debug(f"📡 从Yahoo Finance获取 {request.symbol} 数据")
        
        try:
            import yfinance as yf
            
            # 下载数据
            ticker = yf.Ticker(request.symbol)
            
            # 根据间隔选择不同的参数
            interval_map = {
                "1d": "1d",
                "1h": "1h",
                "30m": "30m",
                "15m": "15m",
                "5m": "5m",
                "1m": "1m"
            }
            
            interval = interval_map.get(request.interval, "1d")
            
            df = ticker.history(
                start=request.start_date,
                end=request.end_date,
                interval=interval,
                auto_adjust=True
            )
            
            if df.empty:
                logger.warning(f"⚠️  Yahoo Finance返回空数据: {request.symbol}")
                return pd.DataFrame()
            
            # 重命名列
            df.index.name = 'datetime'
            
            # 标准化列名
            column_mapping = {
                'Open': 'open',
                'High': 'high',
                'Low': 'low',
                'Close': 'close',
                'Volume': 'volume',
                'Dividends': 'dividends',
                'Stock Splits': 'splits'
            }
            
            df = df.rename(columns=column_mapping)
            
            # 只保留请求的字段
            available_columns = [col for col in request.fields if col in df.columns]
            if not available_columns:
                available_columns = ['open', 'high', 'low', 'close', 'volume']
            
            result = df[available_columns]
            
            logger.debug(f"✅ Yahoo Finance获取成功: {len(result)} 条数据")
            return result
            
        except Exception as e:
            logger.error(f"❌ Yahoo Finance获取失败: {e}")
            return pd.DataFrame()
    
    async def _fetch_mock_data(self, request: DataRequest) -> pd.DataFrame:
        """生成模拟数据"""
        logger.debug(f"🎲 生成模拟数据: {request.symbol}")
        
        try:
            # 生成日期范围
            start_date = pd.to_datetime(request.start_date)
            end_date = pd.to_datetime(request.end_date)
            
            if request.interval == "1d":
                freq = "D"
            elif request.interval == "1h":
                freq = "H"
            elif request.interval in ["5m", "15m", "30m"]:
                freq = request.interval
            else:
                freq = "D"
            
            dates = pd.date_range(start=start_date, end=end_date, freq=freq)
            
            if len(dates) == 0:
                logger.warning("⚠️  模拟数据日期范围无效")
                return pd.DataFrame()
            
            # 生成随机价格数据（有趋势的随机游走）
            np.random.seed(hash(request.symbol) % 10000)
            
            n_points = len(dates)
            base_price = 100.0
            
            # 随机游走
            returns = np.random.randn(n_points) * 0.02  # 2% daily volatility
            prices = base_price * (1 + returns).cumprod()
            
            # 生成OHLCV数据
            df = pd.DataFrame(index=dates)
            df['open'] = prices * (1 + np.random.randn(n_points) * 0.005)
            df['high'] = df['open'] * (1 + np.random.rand(n_points) * 0.03)
            df['low'] = df['open'] * (1 - np.random.rand(n_points) * 0.03)
            df['close'] = prices
            df['volume'] = np.random.randint(1000, 10000, n_points)
            
            # 确保 high >= low
            df['high'] = df[['high', 'low']].max(axis=1)
            df['low'] = df[['high', 'low']].min(axis=1)
            
            # 确保 high >= open, high >= close, low <= open, low <= close
            df['high'] = df[['high', 'open', 'close']].max(axis=1)
            df['low'] = df[['low', 'open', 'close']].min(axis=1)
            
            # 只保留请求的字段
            available_columns = [col for col in request.fields if col in df.columns]
            if not available_columns:
                available_columns = ['open', 'high', 'low', 'close', 'volume']
            
            result = df[available_columns]
            
            logger.debug(f"✅ 模拟数据生成成功: {len(result)} 条数据")
            return result
            
        except Exception as e:
            logger.error(f"❌ 模拟数据生成失败: {e}")
            return pd.DataFrame()
    
    async def _fetch_mock_data_response(self, request: DataRequest) -> DataResponse:
        """获取模拟数据响应"""
        start_time = datetime.now()
        
        data = await self._fetch_mock_data(request)
        
        return DataResponse(
            symbol=request.symbol,
            data=data,
            source=DataSourceType.MOCK,
            request_time=start_time,
            success=True,
            metadata={
                "data_points": len(data),
                "columns": list(data.columns),
                "date_range": {
                    "start": data.index[0].strftime("%Y-%m-%d") if len(data) > 0 else None,
                    "end": data.index[-1].strftime("%Y-%m-%d") if len(data) > 0 else None
                },
                "fetch_duration": (datetime.now() - start_time).total_seconds(),
                "from_cache": False,
                "source_used": "mock",
                "is_mock_data": True
            }
        )
    
    def _standardize_data(self, data: pd.DataFrame, request: DataRequest) -> pd.DataFrame:
        """标准化数据格式"""
        if data.empty:
            return data
        
        # 确保索引是datetime
        if not isinstance(data.index, pd.DatetimeIndex):
            try:
                data.index = pd.to_datetime(data.index)
            except:
                logger.warning("⚠️  无法将索引转换为datetime")
                pass
        
        # 标准化列名
        column_standardization = {
            'Open': 'open',
            'High': 'high', 
            'Low': 'low',
            'Close': 'close',
            'Volume': 'volume',
            'Adj Close': 'adj_close',
            '成交额': 'amount',
            '涨跌幅': 'change_pct',
            '振幅': 'amplitude',
            '换手率': 'turnover',
            '涨跌额': 'change'
        }
        
        data = data.rename(columns={k: v for k, v in column_standardization.items() if k in data.columns})
        
        # 排序索引
        data.sort_index(inplace=True)
        
        # 确保数据类型正确
        numeric_columns = ['open', 'high', 'low', 'close', 'volume', 'amount', 'change_pct', 'amplitude', 'turnover', 'change']
        for col in numeric_columns:
            if col in data.columns:
                data[col] = pd.to_numeric(data[col], errors='coerce')
        
        # 处理缺失值
        data = data.fillna(method='ffill').fillna(method='bfill')
        
        return data
    
    async def batch_fetch(self, requests: List[DataRequest]) -> List[DataResponse]:
        """
        批量获取数据
        
        Args:
            requests: 数据请求列表
            
        Returns:
            数据响应列表
        """
        logger.info(f"📦 批量获取 {len(requests)} 个数据请求...")
        
        tasks = []
        for request in requests:
            tasks.append(self.fetch_data(request))
        
        responses = await asyncio.gather(*tasks, return_exceptions=True)
        
        # 处理结果
        valid_responses = []
        for i, response in enumerate(responses):
            if isinstance(response, DataResponse):
                valid_responses.append(response)
            elif isinstance(response, Exception):
                logger.error(f"❌ 请求 {requests[i].symbol} 失败: {response}")
                valid_responses.append(DataResponse(
                    symbol=requests[i].symbol,
                    data=pd.DataFrame(),
                    source=requests[i].source,
                    request_time=datetime.now(),
                    success=False,
                    error_message=str(response)
                ))
        
        success_count = sum(1 for r in valid_responses if r.success)
        total_data_points = sum(len(r.data) for r in valid_responses if r.success)
        
        logger.info(f"✅ 批量获取完成，成功: {success_count}/{len(requests)}, 总数据点: {total_data_points}")
        
        return valid_responses
    
    def clear_cache(self):
        """清空缓存"""
        self.cache.clear()
        logger.info("🧹 缓存已清空")
    
    def get_cache_stats(self) -> Dict[str, Any]:
        """获取缓存统计"""
        return {
            "cache_size": len(self.cache),
            "cache_keys": list(self.cache.keys()),
            "config": {
                "enable_cache": self.config["enable_cache"],
                "cache_duration": self.config["cache_duration"]
            }
        }

# 示例使用
async def example_usage():
    """示例用法"""
    print("🚀 多数据源适配器示例")
    print("=" * 60)
    
    # 创建适配器配置
    config = {
        "default_timeout": 30,
        "max_retries": 3,
        "cache_duration": 300,
        "rate_limit_per_source": 5,
        "enable_cache": True,
        "enable_fallback": True,
        "fallback_order": ["akshare", "tushare", "yfinance", "mock"]
    }
    
    # 创建适配器
    async with MultiSourceAdapter(config=config) as adapter:
        # 创建数据请求
        requests = [
            DataRequest(
                symbol="000001.SZ",  # 平安银行
                start_date="2024-01-01",
                end_date="2024-03-31",
                source=DataSourceType.AKSHARE,
                fields=["open", "high", "low", "close", "volume", "amount"]
            ),
            DataRequest(
                symbol="AAPL",
                start_date="2024-01-01",
                end_date="2024-03-31",
                source=DataSourceType.YFINANCE,
                fields=["open", "high", "low", "close", "volume"]
            ),
            DataRequest(
                symbol="600519.SH",  # 贵州茅台
                start_date="2024-01-01",
                end_date="2024-03-31",
                source=DataSourceType.TUSHARE,
                fields=["open", "high", "low", "close", "volume", "change_pct"]
            )
        ]
        
        # 批量获取数据
        print("📥 批量获取数据中...")
        responses = await adapter.batch_fetch(requests)
        
        # 输出结果
        print("\n📊 数据获取结果:")
        print("=" * 60)
        print(f"{'股票':<12} {'数据源':<12} {'状态':<8} {'数据点':<8} {'时间范围':<25}")
        print("-" * 60)
        
        for response in responses:
            status = "✅" if response.success else "❌"
            data_source = response.source.value
            
            if response.success and not response.data.empty:
                date_range = f"{response.data.index[0].strftime('%Y-%m-%d')} 到 {response.data.index[-1].strftime('%Y-%m-%d')}"
                data_points = len(response.data)
            else:
                date_range = "N/A"
                data_points = 0
            
            print(f"{response.symbol:<12} {data_source:<12} {status:<8} {data_points:<8} {date_range:<25}")
            
            # 显示数据摘要
            if response.success and not response.data.empty:
                summary = response.get_summary()
                print(f"   摘要: {summary['data_points']} 数据点, {len(summary['columns'])} 列")
                
                # 显示前几行数据
                if not response.data.empty:
                    print(f"   前3行数据:")
                    print(response.data.head(3).to_string())
                    print()
        
        print("=" * 60)
        
        # 显示缓存统计
        cache_stats = adapter.get_cache_stats()
        print(f"\n📦 缓存统计:")
        print(f"   缓存大小: {cache_stats['cache_size']}")
        print(f"   缓存启用: {cache_stats['config']['enable_cache']}")
        print(f"   缓存时长: {cache_stats['config']['cache_duration']}秒")
        
        # 测试单个请求
        print("\n🧪 测试单个请求...")
        single_request = DataRequest(
            symbol="TSLA",
            start_date="2024-04-01",
            end_date="2024-04-10",
            source=DataSourceType.YFINANCE,
            interval="1d"
        )
        
        single_response = await adapter.fetch_data(single_request)
        
        if single_response.success:
            print(f"✅ 单个请求成功: {single_response.symbol}")
            print(f"   数据点: {len(single_response.data)}")
            print(f"   耗时: {single_response.metadata.get('fetch_duration', 0):.2f}秒")
            
            if not single_response.data.empty:
                print(f"   数据预览:")
                print(single_response.data.head().to_string())
        else:
            print(f"❌ 单个请求失败: {single_response.error_message}")
        
        # 清空缓存
        adapter.clear_cache()
        print(f"\n🧹 缓存已清空")

if __name__ == "__main__":
    # 运行示例
    asyncio.run(example_usage())