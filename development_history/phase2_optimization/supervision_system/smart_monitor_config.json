{
  "monitor_intervals": {
    "critical_phase": 15,
    "normal_phase": 30,
    "stable_phase": 60,
    "night_time": 120,
    "early_morning": 180
  },
  "time_ranges": {
    "daytime": [
      "08:00",
      "22:00"
    ],
    "night": [
      "22:00",
      "08:00"
    ],
    "early_morning": [
      "00:00",
      "06:00"
    ]
  },
  "phase_definitions": {
    "critical": [
      "progress_rate < 0.3",
      "quality_score < 90"
    ],
    "normal": [
      "progress_rate >= 0.3",
      "progress_rate <= 0.8"
    ],
    "stable": [
      "progress_rate > 0.8",
      "quality_score >= 95"
    ]
  },
  "adjustment_factors": {
    "quality_high_multiplier": 1.5,
    "quality_low_multiplier": 0.7,
    "max_interval": 180,
    "min_interval": 10
  }
}