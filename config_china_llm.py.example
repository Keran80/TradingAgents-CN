# TradingAgents-CN 中国 LLM 配置文件模板
# 使用方法：将此文件复制为 config.py 并填入你的 API Key

import os

# ============================================================
# 方法一：直接配置（推荐）
# ============================================================

# 方式 1: 使用 DeepSeek（性价比高）
DEEPSEEK_CONFIG = {
    "llm_provider": "deepseek",
    "deep_think_llm": "deepseek-chat",
    "quick_think_llm": "deepseek-chat",
    "deepseek_api_key": "your-deepseek-api-key-here",  # 替换为你的 API Key
}

# 方式 2: 使用智谱清言 GLM-4
ZHIPU_CONFIG = {
    "llm_provider": "zhipu",
    "deep_think_llm": "glm-4",
    "quick_think_llm": "glm-4-flash",
    "zhipu_api_key": "your-zhipu-api-key-here",  # 替换为你的 API Key
}

# 方式 3: 使用通义千问 Qwen
QWEN_CONFIG = {
    "llm_provider": "qwen",
    "deep_think_llm": "qwen-plus",
    "quick_think_llm": "qwen-turbo",
    "qwen_api_key": "your-qwen-api-key-here",  # 替换为你的 API Key
}

# 方式 4: 使用文心一言 ERNIE
WENXIN_CONFIG = {
    "llm_provider": "wenxin",
    "deep_think_llm": "ernie-3.5-8k",
    "quick_think_llm": "ernie-speed-8k",
    "wenxin_api_key": "your-wenxin-api-key-here",  # 替换为你的 API Key
}

# 方式 5: 使用讯飞星火 Spark
SPARK_CONFIG = {
    "llm_provider": "spark",
    "deep_think_llm": "spark-v3.5",
    "quick_think_llm": "spark-v3.5",
    "spark_api_key": "your-spark-api-key-here",  # 替换为你的 API Key
    "spark_app_id": "your-spark-app-id-here",    # 替换为你的 App ID
}


# ============================================================
# 方法二：环境变量配置
# ============================================================
#
# 设置环境变量后，框架会自动读取：
# 
# export DEEPSEEK_API_KEY="your-key"
# export ZHIPU_API_KEY="your-key"
# export QWEN_API_KEY="your-key"
# export WENXIN_API_KEY="your-key"
# export SPARK_API_KEY="your-key"
# export SPARK_APP_ID="your-app-id"
#
# export TRADINGAGENTS_LLM_PROVIDER="deepseek"  # 或 zhipu/qwen/wenxin/spark
# export TRADINGAGENTS_DEEP_LLM="deepseek-chat"
# export TRADINGAGENTS_QUICK_LLM="deepseek-chat"


